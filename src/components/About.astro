---
const values = [
  {
    icon: "💡",
    title: "Innovation First",
    description: "We stay at the forefront of technology, constantly exploring new approaches to solve complex challenges.",
  },
  {
    icon: "🎯",
    title: "Quality Driven",
    description: "Every line of code we write is crafted with precision, following industry best practices and clean architecture.",
  },
  {
    icon: "🤝",
    title: "True Partnership",
    description: "We don't just deliver code — we become your technology partner, committed to your long-term success.",
  },
  {
    icon: "⚡",
    title: "Agile & Efficient",
    description: "Our streamlined processes ensure rapid delivery without compromising quality or reliability.",
  },
];
---

<section class="about section" id="about">
  <div class="container">
    <div class="about__grid">
      <div class="about__content animate-on-scroll">
        <span class="section-label">About Neatlab</span>
        <h2 class="section-title" style="text-align: left;">
          Crafting technology that makes a difference
        </h2>
        <p class="about__text">
          <strong>Neatlab</strong> is a technology company founded with a clear mission: 
          to build high-quality software solutions that empower businesses to thrive in the digital age. 
          Based in Vietnam, we combine local talent with global standards.
        </p>
        <p class="about__text">
          We're not just developers — we're problem solvers. Whether it's building our own 
          innovative products or helping clients bring their ideas to life through custom development, 
          we approach every project with the same level of dedication and craftsmanship.
        </p>
      </div>

      <div class="about__values stagger-children">
        {values.map((value) => (
          <div class="about__value-card animate-on-scroll">
            <span class="about__value-icon">{value.icon}</span>
            <div>
              <h3 class="about__value-title">{value.title}</h3>
              <p class="about__value-desc">{value.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @import "../styles/global.css";

  .about {
    background: var(--color-white);
  }

  .about__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .about__text {
    font-size: var(--font-size-lg);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .about__text strong {
    color: var(--color-navy);
    font-weight: 600;
  }

  .about__values {
    display: grid;
    gap: var(--space-lg);
  }

  .about__value-card {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-bg);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    transition: all var(--transition-base);
  }

  .about__value-card:hover {
    border-color: var(--color-turquoise);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .about__value-icon {
    font-size: var(--font-size-2xl);
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(45, 212, 191, 0.1);
    border-radius: var(--radius-lg);
  }

  .about__value-title {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-xs);
  }

  .about__value-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    line-height: 1.6;
  }

  @media (max-width: 1024px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
    }
  }

  @media (max-width: 768px) {
    .about__value-card {
      flex-direction: column;
      gap: var(--space-md);
      padding: var(--space-lg);
    }
  }
</style>
