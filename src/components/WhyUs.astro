---
const features = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "Support Triage Automation",
    description: "Route and prioritize inbound requests automatically so teams handle urgent issues faster and reduce manual sorting.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "Meeting Summary Workflows",
    description: "Convert meetings into structured notes, decisions, and action items so execution continues without manual recap.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`,
    title: "Lead Qualification Automation",
    description: "Score, enrich, and route incoming leads based on defined criteria to improve response speed and sales focus.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    title: "Invoice Processing Automation",
    description: "Extract and validate invoice data with AI, then push results into accounting or ERP workflows with fewer errors.",
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>`,
    title: "Internal Knowledge Assistant",
    description: "Give teams fast access to internal SOPs and answers through an AI assistant connected to trusted knowledge sources.",
  },
];
---

<section class="whyus section" id="why-us">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Priority Use Cases</span>
      <h2 class="section-title">High-impact AI automation workflows we implement first</h2>
      <p class="section-subtitle">
        We focus on workflows that are easy to validate, practical to deploy,
        and clearly tied to business outcomes.
      </p>
    </div>

    <div class="whyus__grid stagger-children">
      {features.map((feature) => (
        <div class="whyus__card animate-on-scroll">
          <div class="whyus__card-icon" set:html={feature.icon} />
          <h3 class="whyus__card-title">{feature.title}</h3>
          <p class="whyus__card-desc">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @import "../styles/global.css";

  .whyus {
    background: var(--color-white);
  }

  .whyus__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .whyus__card {
    padding: var(--space-2xl);
    border-radius: var(--radius-2xl);
    background: var(--color-bg);
    border: 1px solid transparent;
    transition: all var(--transition-base);
    text-align: center;
  }

  .whyus__card:hover {
    border-color: var(--color-border);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .whyus__card-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-primary);
    color: var(--color-turquoise);
    border-radius: var(--radius-xl);
    margin: 0 auto var(--space-lg);
  }

  .whyus__card-title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-sm);
  }

  .whyus__card-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .whyus__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .whyus__grid {
      grid-template-columns: 1fr;
      max-width: 500px;
      margin: 0 auto;
    }
  }
</style>
