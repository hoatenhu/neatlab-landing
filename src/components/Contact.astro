---

---

<section class="contact section" id="contact">
  <div class="contact__bg">
    <div class="contact__orb contact__orb--1"></div>
    <div class="contact__orb contact__orb--2"></div>
  </div>

  <div class="container">
    <div class="contact__inner animate-on-scroll">
      <div class="contact__content">
        <span class="section-label" style="color: var(--color-turquoise);"
          >Get in Touch</span
        >
        <h2 class="contact__title">Ready to identify your first AI automation win?</h2>
        <p class="contact__subtitle">
          Book an AI Automation Audit with Neatlab. Share your current workflow,
          and we will propose a practical automation roadmap with clear ROI direction.
        </p>

        <div class="contact__info">
          <div class="contact__info-item">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
            <a href="mailto:admin@neatlab.tech">admin@neatlab.tech</a>
          </div>
          <div class="contact__info-item">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
            <span>Ho Chi Minh City, Vietnam</span>
          </div>
        </div>
      </div>

      <form class="contact__form" id="contact-form">
        <div class="contact__form-row">
          <div class="contact__form-group">
            <label for="name" class="contact__label">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              class="contact__input"
              placeholder="Your name"
              required
            />
          </div>
          <div class="contact__form-group">
            <label for="email" class="contact__label">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="contact__input"
              placeholder="your@email.com"
              required
            />
          </div>
        </div>
        <div class="contact__form-group">
            <label for="subject" class="contact__label">Team / Workflow</label>
            <input
              type="text"
              id="subject"
              name="subject"
              class="contact__input"
              placeholder="e.g. Support inbox triage"
            />
          </div>
        <div class="contact__form-group">
          <label for="message" class="contact__label">Message</label>
            <textarea
              id="message"
              name="message"
              class="contact__input contact__textarea"
              placeholder="Describe your current process, pain points, and expected outcome..."
              rows="4"
              required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg contact__submit">
          Book an Automation Audit
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  @import "../styles/global.css";

  .contact {
    background: var(--gradient-hero);
    position: relative;
    overflow: hidden;
  }

  .contact__bg {
    position: absolute;
    inset: 0;
  }

  .contact__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.1;
  }

  .contact__orb--1 {
    width: 500px;
    height: 500px;
    background: var(--color-turquoise);
    top: -200px;
    left: -100px;
  }

  .contact__orb--2 {
    width: 400px;
    height: 400px;
    background: var(--color-turquoise-light);
    bottom: -150px;
    right: -100px;
  }

  .contact__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .contact__title {
    font-size: var(--font-size-4xl);
    font-weight: 800;
    color: var(--color-white);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-lg);
  }

  .contact__subtitle {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact__info-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
  }

  .contact__info-item svg {
    color: var(--color-turquoise);
    flex-shrink: 0;
  }

  .contact__info-item a {
    color: rgba(255, 255, 255, 0.7);
    transition: color var(--transition-fast);
  }

  .contact__info-item a:hover {
    color: var(--color-turquoise);
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-2xl);
    padding: var(--space-2xl);
  }

  .contact__form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .contact__label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-sm);
  }

  .contact__input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-lg);
    color: var(--color-white);
    font-family: var(--font-family);
    font-size: var(--font-size-sm);
    outline: none;
    transition: all var(--transition-fast);
  }

  .contact__input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .contact__input:focus {
    border-color: var(--color-turquoise);
    background: rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 0 3px rgba(45, 212, 191, 0.15);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__submit {
    width: 100%;
  }

  @media (max-width: 1024px) {
    .contact__inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }

  @media (max-width: 768px) {
    .contact__title {
      font-size: var(--font-size-2xl);
    }

    .contact__form-row {
      grid-template-columns: 1fr;
    }

    .contact__form {
      padding: var(--space-xl);
    }
  }
</style>
