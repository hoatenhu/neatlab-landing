---
const services = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    title: "AI Automation Audit",
    description:
      "Identify the best workflows to automate first based on business impact, implementation effort, and measurable ROI.",
    features: ["Workflow Discovery", "Pain Point Analysis", "ROI Prioritization", "Automation Roadmap"],
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: "AI Workflow Implementation",
    description:
      "Design, build, and launch AI-powered workflows integrated with your existing tools, data sources, and team processes.",
    features: ["Workflow Design", "AI Prompt Logic", "Tool Integration", "Enablement & Handover"],
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Ongoing Optimization",
    description:
      "Continuously improve quality and performance after go-live to maintain ROI, reliability, and adoption across teams.",
    features: ["Performance Monitoring", "Prompt Tuning", "Expansion Backlog", "Monthly Optimization Review"],
  },
];
---

<section class="services section" id="services">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="section-label">Service Offers</span>
      <h2 class="section-title">Three offers to launch and scale AI automation</h2>
      <p class="section-subtitle">
        Start with the right automation opportunity, implement high-impact workflows,
        then optimize continuously for stronger business outcomes.
      </p>
    </div>

    <div class="services__grid stagger-children">
      {services.map((service) => (
        <div class="services__card animate-on-scroll">
          <div class="services__card-icon" set:html={service.icon} />
          <h3 class="services__card-title">{service.title}</h3>
          <p class="services__card-desc">{service.description}</p>
          <ul class="services__card-features">
            {service.features.map((feature) => (
              <li class="services__card-feature">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @import "../styles/global.css";

  .services {
    background: var(--color-bg);
  }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .services__card {
    background: var(--color-white);
    border-radius: var(--radius-2xl);
    padding: var(--space-2xl);
    border: 1px solid var(--color-border);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .services__card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--gradient-accent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .services__card:hover {
    border-color: var(--color-turquoise);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .services__card:hover::before {
    opacity: 1;
  }

  .services__card-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(45, 212, 191, 0.1);
    color: var(--color-turquoise);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-xl);
  }

  .services__card-title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: var(--space-md);
  }

  .services__card-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .services__card-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .services__card-feature {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  .services__card-feature svg {
    color: var(--color-turquoise);
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .services__grid {
      grid-template-columns: 1fr;
      max-width: 600px;
      margin: 0 auto;
    }
  }
</style>
